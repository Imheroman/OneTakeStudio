# =====================================================
# OneTakeStudio Backend Environment Variables
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# =====================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# =====================================================
# 공통 설정 (모든 서비스)
# =====================================================

# JWT (모든 서비스에서 동일해야 함, base64 인코딩 필수)
# 생성 방법: echo -n "your-secret-key-at-least-32-chars" | base64
JWT_SECRET=eW91ci1wcm9kdWN0aW9uLWp3dC1zZWNyZXQta2V5LW11c3QtYmUtYXQtbGVhc3QtMjU2LWJpdHM=

# Eureka
EUREKA_URL=http://eureka-server:8761/eureka/

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# =====================================================
# Core Service
# =====================================================

# Database
DB_URL=jdbc:mysql://mysql:3306/core_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=core_user
DB_PASSWORD=your_secure_password

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URI=https://yourdomain.com/oauth/callback

# OAuth - Kakao
OAUTH_KAKAO_CLIENT_ID=your-kakao-client-id
OAUTH_KAKAO_CLIENT_SECRET=your-kakao-client-secret
OAUTH_KAKAO_REDIRECT_URI=https://yourdomain.com/oauth/callback

# OAuth - Naver
OAUTH_NAVER_CLIENT_ID=your-naver-client-id
OAUTH_NAVER_CLIENT_SECRET=your-naver-client-secret
OAUTH_NAVER_REDIRECT_URI=https://yourdomain.com/oauth/callback

# AI Service
AI_SERVICE_URL=http://ai-service:8000
AI_WEBHOOK_URL=http://core-service:8080/api/ai/webhook

# Media Service
MEDIA_SERVICE_URL=http://media-service:8082

# Storage
STORAGE_BASE_PATH=/mnt/storage

# =====================================================
# Media Service
# =====================================================

# Database (Media 전용)
# DB_URL, DB_USERNAME, DB_PASSWORD는 위에서 설정

# LiveKit
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret-must-be-at-least-32-chars

# Core Service
CORE_SERVICE_URL=http://core-service:8080

# Recording
RECORDING_BASE_PATH=/recordings
RECORDING_BASE_URL=https://yourdomain.com/api/media/record/files

# =====================================================
# API Gateway
# =====================================================

SERVER_PORT=60000

# =====================================================
# Logging (Optional)
# =====================================================

LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN
LOG_LEVEL_GATEWAY=WARN
